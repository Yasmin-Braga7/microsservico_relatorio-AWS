pipeline {
    agent any
    
    environment {
        PROJECT_NAME = 'microsservico_relatorio'
    }

    stages {
        stage('Checkout') {
            steps {
                // Clona o repositório
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                // Comando shell para Linux
                sh 'docker-compose build'
            }
        }

        stage('Deploy') {
            steps {
                // Comando shell para Linux para subir os containers
                sh 'docker-compose up -d'
            }
        }
    }

    post {
        always {
            echo 'Pipeline Linux finalizada!'
        }
        success {
            echo 'Deploy realizado com sucesso no ambiente Linux.'
        }
        failure {
            echo 'Ocorreu um erro no pipeline do Linux.'
        }
    }
}
